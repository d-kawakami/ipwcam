<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fitsSystemWindows="true"
    android:padding="24dp">

    <!-- アプリタイトル -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ipwcam"
        android:textColor="#E94560"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MJPEG Video Streamer"
        android:textColor="#888888"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvIcon"
        android:layout_marginTop="6dp" />

    <!-- アイコン -->
    <ImageView
        android:id="@+id/tvIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@drawable/icon_bg_round"
        android:scaleType="fitXY"
        android:padding="4dp"
        android:contentDescription="ipcam icon"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnHostQR"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- QRコードを表示して配信開始ボタン -->
    <Button
        android:id="@+id/btnHostQR"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="QRコードを表示して配信開始"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#0F7B6C"
        app:layout_constraintTop_toBottomOf="@id/tvIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnScanQR"
        android:layout_marginBottom="8dp" />

    <!-- QRコード読み込みボタン -->
    <Button
        android:id="@+id/btnScanQR"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="QRコードを読み込んで配信開始"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#E94560"
        app:layout_constraintTop_toBottomOf="@id/btnHostQR"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvOr" />

    <!-- 区切り -->
    <TextView
        android:id="@+id/tvOr"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="─── または ───"
        android:textColor="#555577"
        android:textSize="13sp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/btnScanQR"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tilServerUrl"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp" />

    <!-- URL手入力フィールド -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilServerUrl"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="配信先URL (例: http://192.168.x.x:5500/video)"
        app:hintTextColor="#AAAAAA"
        app:boxStrokeColor="#E94560"
        app:boxBackgroundColor="#22223A"
        app:layout_constraintTop_toBottomOf="@id/tvOr"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnConnect">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#666688"
            android:text="http://192.168.x.x:5500/video"
            android:inputType="textUri"
            android:imeOptions="actionGo"
            android:fontFamily="monospace"
            android:textSize="13sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 接続ボタン -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="接続して配信開始"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:backgroundTint="#0F3460"
        app:layout_constraintTop_toBottomOf="@id/tilServerUrl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvStatus"
        android:layout_marginTop="10dp" />

    <!-- ステータステキスト -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="配信先をQRコードまたは直接入力で指定してください"
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
