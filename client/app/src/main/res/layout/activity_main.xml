<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <!-- タイトル -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ipwcam"
            android:textColor="#E94560"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MJPEG Video Streamer"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp" />

        <!-- アイコン -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/icon_bg_round"
            android:scaleType="fitXY"
            android:padding="4dp"
            android:contentDescription="ipcam icon"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- ─── 端末間ダイレクト通信 ─── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="#0F7B6C"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="端末間ダイレクト通信"
                    android:textColor="#0F7B6C"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="サーバー不要 — 端末同士で直接カメラ映像を送受信"
                    android:textColor="#668888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <!-- 配信側：QRを表示して配信 -->
                <Button
                    android:id="@+id/btnHostQR"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="QRコードを表示して配信開始"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#0F7B6C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自分のカメラを配信する（QRを相手に読ませる）"
                    android:textColor="#556666"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp" />

                <!-- 受信側：QRを読み込んで受信 -->
                <Button
                    android:id="@+id/btnScanView"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="QRコードを読み込んで受信開始"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#0077B6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="相手の配信QRをスキャンして映像を受信する"
                    android:textColor="#556677"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Flaskサーバー連携 ─── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="#E94560"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Flaskサーバー連携"
                    android:textColor="#E94560"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PCサーバー経由 — ブラウザでカメラ映像を視聴"
                    android:textColor="#886668"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <!-- QRスキャンで配信開始 -->
                <Button
                    android:id="@+id/btnScanQR"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="QRコードを読み込んで配信開始"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#E94560" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="サーバーのQRをスキャンして自分のカメラを配信する"
                    android:textColor="#886668"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="14dp"
                    android:layout_marginStart="4dp" />

                <!-- 区切り線 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A4A"
                    android:layout_marginBottom="14dp" />

                <!-- URL手入力 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilServerUrl"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="配信先URL (例: http://192.168.x.x:5500/video)"
                    app:hintTextColor="#AAAAAA"
                    app:boxStrokeColor="#E94560"
                    app:boxBackgroundColor="#22223A">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etServerUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666688"
                        android:text="http://192.168.x.x:5500/video"
                        android:inputType="textUri"
                        android:imeOptions="actionGo"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnConnect"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="接続して配信開始"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#0F3460"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="URLを直接入力してサーバーへ配信する"
                    android:textColor="#556677"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ヒント -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="端末間通信はサーバー不要。Flaskサーバー連携はPC側でサーバー起動が必要です。"
            android:textColor="#555577"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</ScrollView>
